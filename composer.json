{
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "require": {
        "cebe/markdown": "~1.1.1",
        "twig/twig": "^3.0",
        "shipwebdotjp/line-bot-sdk": "^6.1"
    },
    "require-dev": {
        "vlucas/phpdotenv": "^5.6",
        "phpunit/phpunit": "^9.0",
        "yoast/phpunit-polyfills": "^3.1",
        "rector/rector": "^2.0",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Shipweb\\LineConnect\\": "src/"
        }
    },
    "autoload-dev": {
        "classmap": [
            "tests"
        ],
        "psr-4": {
            "Rector\\Rules\\": "rector/rules/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/shipwebdotjp/line-bot-sdk"
        }
    ]
}
